{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@obscura/contracts": ["packages/contracts/src/index.ts"],
      "@obscura/db": ["packages/db/src/index.ts"],
      "@obscura/db/*": ["packages/db/*"],
      "@obscura/media-core": ["packages/media-core/src/index.ts"],
      "@obscura/stash-import": ["packages/stash-import/src/index.ts"],
      "@obscura/ui": ["packages/ui/src/index.ts"]
    }
  }
}

