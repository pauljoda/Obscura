NODE_ENV=development
POSTGRES_DB=obscura
POSTGRES_USER=obscura
POSTGRES_PASSWORD=obscura
DATABASE_URL=postgresql://obscura:obscura@postgres:5432/obscura
NEXT_PUBLIC_APP_URL=http://localhost:8008
NEXT_PUBLIC_API_URL=http://localhost:4000
INTERNAL_API_URL=http://localhost:4000

# Obscura Community Plugins — set to local path for dev, or remote URL for production
# OBSCURA_PLUGIN_INDEX_PATH=/path/to/obscura-community-plugins
# OBSCURA_PLUGIN_INDEX_URL=https://raw.githubusercontent.com/pauljoda/obscura-community-plugins/main
