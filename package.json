{
  "name": "obscura",
  "version": "0.19.1-dev",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "turbo run lint typecheck",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:web": "vitest run --config apps/web/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:ci": "pnpm test:unit && pnpm test:integration && pnpm test:web",
    "coverage": "pnpm test:unit -- --coverage && pnpm test:integration -- --coverage && pnpm test:web -- --coverage",
    "release:check": "node scripts/release/check-version.mjs",
    "release:cut": "node scripts/release/cut.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-orm": "^0.45.2",
    "jsdom": "^29.0.1",
    "postgres": "^3.4.8",
    "turbo": "^2.0.14",
    "vitest": "^4.1.4"
  }
}
