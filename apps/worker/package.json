{
  "name": "@obscura/worker",
  "version": "0.19.1-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "lint": "tsc --project tsconfig.json --noEmit",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config ../../vitest.integration.config.ts ../../tests/worker.integration.test.ts"
  },
  "dependencies": {
    "@obscura/contracts": "workspace:*",
    "@obscura/db": "workspace:*",
    "@obscura/media-core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg-boss": "^10.3.2",
    "postgres": "^3.4.8",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
