{
  "name": "@obscura/api",
  "version": "0.18.1-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "build": "tsc --project tsconfig.json",
    "lint": "tsc --project tsconfig.json --noEmit",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@obscura/contracts": "workspace:*",
    "@obscura/media-core": "workspace:*",
    "@obscura/stash-import": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "fflate": "^0.8.2",
    "js-yaml": "^4.1.1",
    "pg-boss": "^10.3.2",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
